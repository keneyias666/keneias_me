# ── Flowise Configuration ────────────────────────────────
# Get your chatflow ID from your Flowise dashboard after deploying
# Example: http://localhost:3000/api/v1/prediction/abc123-def456-...
FLOWISE_API_URL=http://localhost:3000/api/v1/prediction/YOUR_CHATFLOW_ID_HERE

# Optional: Only needed if your Flowise instance has API key authentication enabled
FLOWISE_API_KEY=

# ── Flask Configuration ───────────────────────────────────
FLASK_DEBUG=false
PORT=5000
